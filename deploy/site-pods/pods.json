  {
    "kind": "Pod",
    "apiVersion": "v1",
    "metadata": {
      "name": "nats",
      "namespace": "infra",
      "creationTimestamp": null,
      "annotations": {
        "vkube.io/boot-priority": "5",
        "vkube.io/image-policy": "auto",
        "vkube.io/network": "gt",
        "vkube.io/node": "rose1",
        "vkube.io/static-ip": "192.168.200.10"
      }
    },
    "spec": {
      "containers": [
        {
          "name": "nats",
          "image": "192.168.200.3:5000/nats:edge",
          "command": [
            "nats-server",
            "-js",
            "--store_dir",
            "/data",
            "--addr",
            "0.0.0.0",
            "-m",
            "8222"
          ],
          "resources": {},
          "volumeMounts": [
            {
              "name": "data",
              "mountPath": "/data"
            }
          ],
          "livenessProbe": {
            "httpGet": {
              "path": "/healthz",
              "port": 8222
            },
            "periodSeconds": 30,
            "failureThreshold": 3
          },
          "startupProbe": {
            "tcpSocket": {
              "port": 4222
            },
            "initialDelaySeconds": 2,
            "periodSeconds": 2,
            "failureThreshold": 10
          }
        }
      ],
      "restartPolicy": "Always"
    },
    "status": {}
  },
